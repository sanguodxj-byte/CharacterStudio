    <labelKey>CS_Studio_Export_RoleCardArrival_Standing</labelKey>
    <mode>Standing</mode>
    <sortOrder>0</sortOrder>
  </CharacterStudio.Core.CharacterSpawnArrivalDef>

  <CharacterStudio.Core.CharacterSpawnArrivalDef>
    <defName>CS_SpawnArrival_DropPod</defName>
    <labelKey>CS_Studio_Export_RoleCardArrival_DropPod</labelKey>
    <mode>DropPod</mode>
    <sortOrder>10</sortOrder>
  </CharacterStudio.Core.CharacterSpawnArrivalDef>

  <CharacterStudio.Core.CharacterSpawnArrivalDef>
    <defName>CS_SpawnArrival_DropPod_SpecialItem</defName>
    <label>空投舱降落（需殖民地库存含特殊物品）</label>
    <mode>DropPod</mode>
    <sortOrder>15</sortOrder>
    <requiredConditions>
      <li>
        <matchMode>SpecificThingDef</matchMode>
        <thingDefName>PsychicShockLance</thingDefName>
        <minCount>1</minCount>
        <countStackCount>false</countStackCount>
      </li>
    </requiredConditions>
  </CharacterStudio.Core.CharacterSpawnArrivalDef>

  <CharacterStudio.Core.CharacterSpawnEventDef>
    <defName>CS_SpawnEvent_None</defName>
    <labelKey>CS_Studio_Export_RoleCardEvent_None</labelKey>
    <mode>None</mode>
    <sortOrder>0</sortOrder>
  </CharacterStudio.Core.CharacterSpawnEventDef>

  <CharacterStudio.Core.CharacterSpawnEventDef>
    <defName>CS_SpawnEvent_Message</defName>
    <labelKey>CS_Studio_Export_RoleCardEvent_Message</labelKey>
    <mode>Message</mode>
    <sortOrder>10</sortOrder>
  </CharacterStudio.Core.CharacterSpawnEventDef>

  <CharacterStudio.Core.CharacterSpawnEventDef>
    <defName>CS_SpawnEvent_PositiveLetter</defName>
    <labelKey>CS_Studio_Export_RoleCardEvent_PositiveLetter</labelKey>
    <mode>PositiveLetter</mode>
    <sortOrder>20</sortOrder>
  </CharacterStudio.Core.CharacterSpawnEventDef>

  <CharacterStudio.Core.CharacterSpawnEventDef>
    <defName>CS_SpawnEvent_PositiveLetter_LavishMeal5</defName>
    <label>正面来信（需殖民地库存 5 份豪华餐）</label>
    <mode>PositiveLetter</mode>
    <sortOrder>25</sortOrder>
    <requiredConditions>
      <li>
        <matchMode>FoodPreferability</matchMode>
        <foodPreferability>MealLavish</foodPreferability>
        <minCount>5</minCount>
        <countStackCount>true</countStackCount>
      </li>
    </requiredConditions>
  </CharacterStudio.Core.CharacterSpawnEventDef>

  <CharacterStudio.Core.CharacterSpawnEventDef>
    <defName>CS_SpawnEvent_Message_SpecialItem</defName>
    <label>消息提示（需殖民地库存含特殊物品）</label>
    <mode>Message</mode>
    <sortOrder>15</sortOrder>
    <requiredConditions>
      <li>
        <matchMode>SpecificThingDef</matchMode>
        <thingDefName>PsychicShockLance</thingDefName>
        <minCount>1</minCount>
        <countStackCount>false</countStackCount>
      </li>
    </requiredConditions>
  </CharacterStudio.Core.CharacterSpawnEventDef>

  <CharacterStudio.Core.CharacterSpawnEventDef>
    <defName>CS_SpawnEvent_Message_SilverTradeTag</defName>
    <label>消息提示（需殖民地库存含银币类贸易标签）</label>
    <mode>Message</mode>
    <sortOrder>16</sortOrder>
    <requiredConditions>
      <li>
        <matchMode>TradeTag</matchMode>
        <tradeTag>Silver</tradeTag>
        <minCount>100</minCount>
        <countStackCount>true</countStackCount>
      </li>
    </requiredConditions>
  </CharacterStudio.Core.CharacterSpawnEventDef>

  <CharacterStudio.Core.CharacterSpawnEventDef>
    <defName>CS_SpawnEvent_Message_RawFoodCategory</defName>
    <label>消息提示（需殖民地库存含原料食物分类）</label>
    <mode>Message</mode>
    <sortOrder>17</sortOrder>
    <requiredConditions>
      <li>
        <matchMode>ThingCategory</matchMode>
        <categoryDefName>Foods</categoryDefName>
        <minCount>5</minCount>
        <countStackCount>true</countStackCount>
      </li>
    </requiredConditions>
  </CharacterStudio.Core.CharacterSpawnEventDef>

