  </CharacterStudio.Core.CharacterSpawnAnimationDef>

  <CharacterStudio.Core.CharacterSpawnAnimationDef>
    <defName>CS_SpawnAnimation_ExplosionEffect_NotLavishMeal</defName>
    <label>爆裂特效（殖民地库存必须不满足：5 份豪华餐）</label>
    <mode>ExplosionEffect</mode>
    <defaultScale>1.0</defaultScale>
    <sortOrder>65</sortOrder>
    <conditionLogic>Not</conditionLogic>
    <requiredConditions>
      <li>
        <matchMode>FoodPreferability</matchMode>
        <foodPreferability>MealLavish</foodPreferability>
        <minCount>5</minCount>
        <countStackCount>true</countStackCount>
      </li>
    </requiredConditions>
  </CharacterStudio.Core.CharacterSpawnAnimationDef>

</Defs>
