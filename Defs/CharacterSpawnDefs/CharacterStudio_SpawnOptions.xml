  <CharacterStudio.Core.CharacterSpawnAnimationDef>
    <defName>CS_SpawnAnimation_Smoke</defName>
    <labelKey>CS_Studio_Export_RoleCardAnimation_Smoke</labelKey>
    <mode>Smoke</mode>
    <defaultScale>1.0</defaultScale>
    <sortOrder>50</sortOrder>
  </CharacterStudio.Core.CharacterSpawnAnimationDef>

  <CharacterStudio.Core.CharacterSpawnAnimationDef>
    <defName>CS_SpawnAnimation_Smoke_AnyFoodOrSilver</defName>
    <label>烟雾（满足其一：殖民地库存食物或银币标签）</label>
    <mode>Smoke</mode>
    <defaultScale>1.0</defaultScale>
    <sortOrder>55</sortOrder>
    <conditionLogic>Any</conditionLogic>
    <requiredConditions>
      <li>
        <matchMode>ThingCategory</matchMode>
        <categoryDefName>Foods</categoryDefName>
        <minCount>5</minCount>
        <countStackCount>true</countStackCount>
      </li>
      <li>
        <matchMode>TradeTag</matchMode>
        <tradeTag>Silver</tradeTag>
        <minCount>100</minCount>
        <countStackCount>true</countStackCount>
      </li>
    </requiredConditions>
  </CharacterStudio.Core.CharacterSpawnAnimationDef>

  <CharacterStudio.Core.CharacterSpawnAnimationDef>
    <defName>CS_SpawnAnimation_ExplosionEffect</defName>
