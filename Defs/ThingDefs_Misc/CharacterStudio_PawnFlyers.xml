<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="PawnFlyerBase">
    <defName>CS_PawnJumper_Default</defName>
    <label>character studio real jump</label>
    <thingClass>CharacterStudio.Abilities.CharacterStudioPawnFlyer_Default</thingClass>
    <drawOffscreen>true</drawOffscreen>
    <drawerType>RealtimeOnly</drawerType>
    <altitudeLayer>Pawn</altitudeLayer>
    <pawnFlyer>
      <flightDurationMin>0.35</flightDurationMin>
      <flightSpeed>22</flightSpeed>
      <workerClass>PawnFlyerWorker</workerClass>
      <heightFactor>0</heightFactor>
    </pawnFlyer>
  </ThingDef>

  <ThingDef ParentName="PawnFlyerBase">
    <defName>CS_PawnJumper_OffscreenDive</defName>
    <label>character studio offscreen dive</label>
    <thingClass>CharacterStudio.Abilities.CharacterStudioPawnFlyer_OffscreenDive</thingClass>
    <drawOffscreen>true</drawOffscreen>
    <drawerType>RealtimeOnly</drawerType>
    <altitudeLayer>Pawn</altitudeLayer>
    <pawnFlyer>
      <flightDurationMin>0.6</flightDurationMin>
      <flightSpeed>32</flightSpeed>
      <workerClass>PawnFlyerWorker</workerClass>
      <heightFactor>0</heightFactor>
    </pawnFlyer>
  </ThingDef>

  <!-- 跨地图飞行：角色离场 Skyfaller -->
  <!-- 继承通用 SkyfallerBase（不依赖穿梭机贴图），thingClass 使用自定义 FlyPawnLeaving -->
  <ThingDef ParentName="SkyfallerBase">
    <defName>CS_PawnLeavingWorldMap</defName>
    <label>flying pawn (leaving)</label>
    <thingClass>CharacterStudio.Abilities.FlyPawnLeaving</thingClass>
    <skyfaller>
      <reversed>true</reversed>
      <anticipationSound>Shuttle_Leaving</anticipationSound>
      <anticipationSoundTicks>-10</anticipationSoundTicks>
      <ticksToImpactRange>-40~-15</ticksToImpactRange>
      <moteSpawnTime>0.05</moteSpawnTime>
      <shadow>Things/Skyfaller/SkyfallerShadowRectangle</shadow>
      <shadowSize>(3,3)</shadowSize>
      <motesPerCell>1</motesPerCell>
      <angleCurve>
        <points>
          <li>(0,90)</li>
          <li>(1,70)</li>
        </points>
      </angleCurve>
      <zPositionCurve>
        <points>
          <li>(0,0)</li>
          <li>(0.08,2)</li>
        </points>
      </zPositionCurve>
      <speedCurve>
        <points>
          <li>(0,0.2)</li>
          <li>(0.4,0.7)</li>
        </points>
      </speedCurve>
    </skyfaller>
  </ThingDef>

  <!-- 跨地图飞行：角色进场 Skyfaller -->
  <!-- 继承通用 SkyfallerBase（不依赖穿梭机贴图），thingClass 使用自定义 Skyfaller_PawnArriving -->
  <!-- 动画曲线参考原版 DropPodIncoming，但 reversed=false 表示从高空降落 -->
  <ThingDef ParentName="SkyfallerBase">
    <defName>CS_PawnArrivingWorldMap</defName>
    <label>flying pawn (arriving)</label>
    <thingClass>CharacterStudio.Abilities.Skyfaller_PawnArriving</thingClass>
    <skyfaller>
      <anticipationSound>Shuttle_Arriving</anticipationSound>
      <anticipationSoundTicks>-10</anticipationSoundTicks>
      <ticksToImpactRange>40~60</ticksToImpactRange>
      <moteSpawnTime>0.05</moteSpawnTime>
      <shadow>Things/Skyfaller/SkyfallerShadowRectangle</shadow>
      <shadowSize>(3,3)</shadowSize>
      <motesPerCell>1</motesPerCell>
      <angleCurve>
        <points>
          <li>(0,70)</li>
          <li>(1,90)</li>
        </points>
      </angleCurve>
      <zPositionCurve>
        <points>
          <li>(0,20)</li>
          <li>(0.9,2)</li>
          <li>(1,0)</li>
        </points>
      </zPositionCurve>
      <speedCurve>
        <points>
          <li>(0,0.5)</li>
          <li>(0.6,1.5)</li>
          <li>(1,3)</li>
        </points>
      </speedCurve>
    </skyfaller>
  </ThingDef>

</Defs>
