  <CharacterStudio.Abilities.ModularAbilityDef>
    <defName>CS_Example_Q1_ModeSlash</defName>
    <label>Q1·智能跃斩</label>
    <description>示例：Q1 朝鼠标方向智能施法，复用原版跳跃动画跃进一格并结算伤害；随后 Q 会立即切换显示为 Q2，但仍需等待 1 秒冷却后才能释放。</description>
    <cooldownTicks>45</cooldownTicks>
    <warmupTicks>0</warmupTicks>
    <charges>1</charges>
    <carrierType>Target</carrierType>
    <targetType>Entity</targetType>
    <useRadius>false</useRadius>
    <areaCenter>Target</areaCenter>
    <range>5</range>
    <effects>
      <li>
        <type>Damage</type>
        <amount>18</amount>
        <duration>0</duration>
        <chance>1</chance>
        <damageDef>Cut</damageDef>
        <summonCount>1</summonCount>
      </li>
    </effects>
    <runtimeComponents>
      <li>
        <type>SmartJump</type>
        <enabled>true</enabled>
        <comboWindowTicks>12</comboWindowTicks>
        <cooldownTicks>45</cooldownTicks>
        <jumpDistance>5</jumpDistance>
        <findCellRadius>2</findCellRadius>
        <triggerAbilityEffectsAfterJump>true</triggerAbilityEffectsAfterJump>
        <useMouseTargetCell>true</useMouseTargetCell>
        <smartCastOffsetCells>1</smartCastOffsetCells>
        <smartCastClampToMaxDistance>true</smartCastClampToMaxDistance>
        <smartCastAllowFallbackForward>true</smartCastAllowFallbackForward>
        <requiredStacks>7</requiredStacks>
        <delayTicks>180</delayTicks>
        <wave1Radius>3</wave1Radius>
        <wave1Damage>80</wave1Damage>
        <wave2Radius>6</wave2Radius>
        <wave2Damage>140</wave2Damage>
        <wave3Radius>9</wave3Radius>
        <wave3Damage>220</wave3Damage>
      </li>
      <li>
        <type>HotkeyOverride</type>
        <enabled>true</enabled>
        <overrideHotkeySlot>Q</overrideHotkeySlot>
        <overrideAbilityDefName>CS_Example_Q2_ModeSlash</overrideAbilityDefName>
        <overrideDurationTicks>60</overrideDurationTicks>
      </li>
      <li>
        <type>FollowupCooldownGate</type>
        <enabled>true</enabled>
        <followupCooldownHotkeySlot>Q</followupCooldownHotkeySlot>
        <followupCooldownTicks>60</followupCooldownTicks>
      </li>
    </runtimeComponents>
  </CharacterStudio.Abilities.ModularAbilityDef>

