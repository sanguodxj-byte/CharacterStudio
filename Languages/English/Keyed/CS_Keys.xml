    <!-- Help Glossary -->
    <CS_Help_Title>Glossary</CS_Help_Title>
    <CS_Help_Layer_Title>Layer</CS_Help_Layer_Title>
    <CS_Help_Layer_Desc>A single image layer that makes up the character's appearance. Multiple layers can be added to create complex skins.</CS_Help_Layer_Desc>
    <CS_Help_Anchor_Title>Anchor</CS_Help_Anchor_Title>
    <CS_Help_Anchor_Desc>The body part to which the layer is attached. The layer moves and rotates with the anchor. For example, attaching to "Head" makes the layer rotate with the head.</CS_Help_Anchor_Desc>
    <CS_Help_Offset_Title>Offset</CS_Help_Offset_Title>
    <CS_Help_Offset_Desc>Adjusts the position of the layer relative to the anchor.\nX: Left/Right\nY: Depth/Layering\nZ: Up/Down</CS_Help_Offset_Desc>
    <CS_Help_OffsetEast_Title>Offset East</CS_Help_OffsetEast_Title>
    <CS_Help_OffsetEast_Desc>Additional offset applied when the character is facing East/West. Used to correct misalignment in side views.</CS_Help_OffsetEast_Desc>
    <CS_Help_Scale_Title>Scale</CS_Help_Scale_Title>
    <CS_Help_Scale_Desc>The magnification scale of the layer. 1.0 is the original size.</CS_Help_Scale_Desc>
    <CS_Help_DrawOrder_Title>Draw Order</CS_Help_DrawOrder_Title>
    <CS_Help_DrawOrder_Desc>Determines the rendering order. Higher values appear in front of lower values.</CS_Help_DrawOrder_Desc>
    <CS_Help_ColorType_Title>Color Type</CS_Help_ColorType_Title>
    <CS_Help_ColorType_Desc>Determines the source of the layer's color.\n- Custom: Use a specific fixed color.\n- Hair/Skin: Automatically use the current character's hair or skin color.</CS_Help_ColorType_Desc>
    <CS_Help_Worker_Title>Worker</CS_Help_Worker_Title>
    <CS_Help_Worker_Desc>The program class controlling rendering logic. Usually "Default". "FaceComponent" is for special facial parts (like eyes) supporting blinking/sleeping states.</CS_Help_Worker_Desc>
    <CS_Help_Animation_Title>Animation</CS_Help_Animation_Title>
    <CS_Help_Animation_Desc>Adds dynamic effects to the layer.\n- Random Twitch: Random twitching, suitable for animal ears.\n- Periodic Swing: Periodic swinging, suitable for tails.</CS_Help_Animation_Desc>

